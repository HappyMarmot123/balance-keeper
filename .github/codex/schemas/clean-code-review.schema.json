{
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "findings", "verificationLimits"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["PASS", "CHANGES_REQUESTED", "BLOCKED"]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "findings": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "path", "line", "title", "reason", "impact", "recommendation"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"]
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 260
          },
          "line": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10000000
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 700
          },
          "impact": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "recommendation": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        }
      }
    },
    "verificationLimits": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      }
    }
  }
}
