{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "functions": {
    "api/*": {
      "supportsCancellation": true
    }
  },
  "regions": ["hnd1"],
  "rewrites": [
    {
      "source": "/healthz",
      "destination": "/api/gateway"
    },
    {
      "source": "/api",
      "destination": "/api/gateway"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/gateway"
    },
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
